<!DOCTYPE html>
<html lang="en">
  <%-include("./partials/head.ejs")%>
  <body>
    <header>
    <h1>Welcome</h1>
    <ul>
      <li><a href="/sign-up">Sign-Up</a></li>
      <%if (locals.user){%>
        <li><a href="/log-out">Log--Out</a></li>
      <%} else{%>
      <li><a href="/sign-in">Sign-In</a></li>
      <%}%>
    </ul>
    </header>
    <div class="message-container">
          <%if (locals.user){%>
      <form action="/message" method="POST" class="message-form">
        <h3>Submit Your Message</h3>
        <label for="title">Title: </label>
        <input type="text" name="title" id="title" required placeholder="Title your message...">
        <label for="message">Message: </label>
        <textarea name="message" id="message" required placeholder="Enter your message here..."></textarea>
        <button type="submit">Submit</button>
      </form>
    <%}%>
    <%messages.map((message)=>{%>
        <div class="message">
          <h3 class="title"><%=message.title%></h3>
          <%if (locals.user && locals.user.member){%>
            <p>Author: <%=message.first_name%> <%=message.last_name%></p>
            <p class="time" id="<%=new Date(message.time).toISOString()%>">At: <%=message.time%></p>
          <%}%>
          <p><%=message.message%></p>
          <%if (locals.user && locals.user.admin){%>
            <button class="delete" type="button">Delete</button>
          <%}%>
        </div>
      <%});%>
      </div>
      <%if (locals.user && locals.user.admin){%>
      <script>
        const body = document.querySelector('body');
        body.addEventListener('click', (e)=>{
          if (e.target.classList.contains("delete")){
            const title = e.target.parentElement.querySelector(".title").textContent;
            const time = e.target.parentElement.querySelector(".time").id.replaceAll(':', "%3a");
            const endpoint = `/${time}&${title}`;
            fetch(endpoint, {method: "DELETE"})
            .then((res)=>{res.json().then((data)=>{window.location.href = data.redirect;})})
            .catch((err)=>{console.log(err)})
          }
        })
      </script>
      <%}%>
  </body>
</html>
