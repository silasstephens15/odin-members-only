<!DOCTYPE html>
<html lang="en">
  <%-include("./partials/head.ejs")%>
  <body>
    <h1>Welcome</h1>
    <ul>
      <li><a href="/sign-up">Sign-Up</a></li>
      <%if (locals.user){%>
        <li><a href="/log-out">Log--Out</a></li>
      <%} else{%>
      <li><a href="/sign-in">Sign-In</a></li>
      <%}%>
    </ul>
    <%if (locals.user){%>
      <form action="/message" method="POST">
        <label for="title">Title: </label>
        <input type="text" name="title" id="title" required placeholder="Title your message...">
        <label for="message">Message: </label>
        <textarea name="message" id="message" required placeholder="Enter your message here..."></textarea>
        <button type="submit">Submit</button>
      </form>
    <%}%>
    <%messages.map((message)=>{%>
        <div class="message">
          <h3><%=message.title%></h3>
          <%if (locals.user){%>
            <p>Author: <%=message.first_name%> <%=message.last_name%></p>
            <p>At: <%=message.time%></p>
          <%}%>
          <p><%=message.message%></p>
        </div>
      <%});%>
  </body>
</html>
