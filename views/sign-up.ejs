<!DOCTYPE html>
<html lang="en">
  <%-include("./partials/head.ejs")%>
  <body>
    <h1>Sign-Up</h1>
    <form action="POST">
      <label for="username">Username: </label>
      <input type="text" name="username" id="username" required />
      <label for="password">Password: </label>
      <input type="password" name="password" id="password" required />
      <label for="full-name">First and Last Name: </label>
      <input type="text" name="full-name" id="full-name" />
      <label for="member">Full Member: </label>
      <input type="checkbox" name="member" id="member" />
      <div class="hidden" style="display: none">
        <label for="member-password">Membership Password: </label>
        <input type="password" name="member-password" id="member-password" />
      </div>
      <button type="submit">Submit</button>
    </form>
    <script>
      const body = document.querySelector("body");
      const hidden = document.querySelector(".hidden");

      body.addEventListener("click", (e) => {
        if (e.target.id === "member" && e.target.checked) {
          hidden.style.display = "block";
        } else if (e.target.id === "member") {
          hidden.style.display = "none";
        }
      });
    </script>
  </body>
</html>
